# Data2Doc example environment
# Copy this file to .env and fill in values:
#   cp .env.example .env
# Or use it with Docker:
#   docker run --env-file .env -p 8080:8080 data2doc

# Required: application mode (the app exits if not set)
# Example values: dev, prod
APP_MODE=dev

# Optional: HTTP server port.
# If omitted, the server defaults to 80.
PORT=80

# Strongly recommended: environment name used by logging/sentry toggles
# The code treats ENV == "Development" as development.
ENV=Development

# Auth mode (auto-selected):
# - If AUTH_JWKS_URL is set -> validates Bearer tokens via JWKS (AuthIdentityMiddleware)
# - If AUTH_JWKS_URL is empty -> uses local HMAC JWT (AuthMiddleware) and enables POST /auth/token

# JWKS mode: set this to validate tokens issued by your IdP
# Example (Auth0): https://YOUR_DOMAIN/.well-known/jwks.json
AUTH_JWKS_URL=

# Optional: if set, requests must contain this client_id in JWT claims
AUTH_EXPECTED_CLIENT_ID=

# Local JWT mode (required when AUTH_JWKS_URL is empty)
SECRETKEY=change-me

# Credentials for POST /auth/token (only used in local JWT mode)
# Use AUTH_USER/AUTH_PASS to avoid collisions with OS env vars (Windows commonly sets USER).
AUTH_USER=admin
AUTH_PASS=admin

# Back-compat (not recommended)
# USER=admin
# PASS=admin

# Optional: token expiration for /auth/token (seconds). If empty/invalid, defaults to a long expiration.
JWT_EXP_SEC=

# Optional: Sentry
SENTRY_DSN=
APP_VERSION=dev
